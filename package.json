{
  "name": "oggregator",
  "private": true,
  "version": "0.0.1",
  "description": "Multi-venue crypto options aggregator dashboard",
  "scripts": {
    "dev:server": "pnpm -r --filter @oggregator/core --filter @oggregator/protocol build && pnpm --filter @oggregator/server dev",
    "dev:web": "pnpm --filter @oggregator/web dev",
    "dev:ingest": "pnpm -r --filter @oggregator/core --filter @oggregator/db --filter @oggregator/protocol build && pnpm --filter @oggregator/ingest dev",
    "dev": "pnpm -r --filter @oggregator/core --filter @oggregator/protocol build && pnpm --filter @oggregator/server --filter @oggregator/web --parallel dev",
    "build": "pnpm -r build",
    "db:migrate": "pnpm --filter @oggregator/db migrate",
    "db:seed:sample": "pnpm --filter @oggregator/db build && pnpm --filter @oggregator/db seed:sample",
    "start": "NODE_ENV=production node packages/server/dist/index.js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "typecheck": "pnpm -r --filter @oggregator/protocol build && pnpm -r typecheck",
    "test": "pnpm -r --filter @oggregator/core --filter @oggregator/protocol build && pnpm -r test:run",
    "precommit": "pnpm typecheck && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.2",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11"
  }
}
