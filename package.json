{
  "name": "oggregator",
  "private": true,
  "version": "0.0.1",
  "description": "Multi-venue crypto options aggregator dashboard",
  "scripts": {
    "dev:server": "pnpm -r --filter @oggregator/core --filter @oggregator/db --filter @oggregator/protocol build && pnpm --filter @oggregator/server dev",
    "dev:landing": "pnpm --filter @oggregator/landing dev",
    "dev:web": "pnpm --filter @oggregator/web dev",
    "dev:ingest": "pnpm -r --filter @oggregator/core --filter @oggregator/db --filter @oggregator/protocol build && pnpm --filter @oggregator/ingest dev",
    "dev": "pnpm -r --filter @oggregator/core --filter @oggregator/db --filter @oggregator/protocol build && pnpm --filter @oggregator/server --filter @oggregator/web --parallel dev",
    "build": "pnpm -r build",
    "build:landing": "pnpm --filter @oggregator/landing build",
    "db:migrate": "pnpm --filter @oggregator/db migrate",
    "db:seed:sample": "pnpm --filter @oggregator/db build && pnpm --filter @oggregator/db seed:sample",
    "start": "NODE_ENV=production node packages/server/dist/index.js",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "typecheck": "pnpm -r --filter @oggregator/protocol build && pnpm -r typecheck",
    "test": "pnpm -r --filter @oggregator/core --filter @oggregator/db --filter @oggregator/protocol build && pnpm -r test:run",
    "test:landing": "pnpm --filter @oggregator/landing test:run",
    "precommit": "pnpm typecheck && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@biomejs/biome": "2.4.9"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "es5-ext",
      "esbuild",
      "sharp"
    ]
  }
}
