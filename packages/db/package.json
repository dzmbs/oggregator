{
  "name": "@oggregator/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "migrate": "node --env-file-if-exists=../../.env dist/migrate.js",
    "seed:sample": "node --env-file-if-exists=../../.env dist/seed-sample.js"
  },
  "dependencies": {
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3"
  }
}
