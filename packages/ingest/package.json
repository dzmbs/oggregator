{
  "name": "@oggregator/ingest",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @oggregator/core build && pnpm --filter @oggregator/db build && tsc --noEmit"
  },
  "dependencies": {
    "@oggregator/core": "workspace:*",
    "@oggregator/db": "workspace:*",
    "dotenv": "^16.4.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
